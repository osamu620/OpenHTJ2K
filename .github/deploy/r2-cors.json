{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://htj2k-demo.pages.dev",
          "https://osamu620.dev",
          "http://localhost:8000",
          "http://localhost:3000"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["*"]
